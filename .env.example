# Backend (copy to backend/.env or set in shell)
PORT=8080
GIN_MODE=debug
DATABASE_PATH=./storage/app.db
# Optional: directory for generated report files (default: <dirname DATABASE_PATH>/reports)
# REPORTS_DIR=/app/storage/reports

JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRY_HOURS=72
# CORS: origin of the browser UI (must match where you open the app).
# Local Vite on host: http://localhost:5173
# docker-compose.dev.yml overrides this for the backend container to http://localhost:${FRONTEND_PORT:-5173}
# Production compose (nginx UI): set to the same origin as the served UI (e.g. http://localhost:8080)
CORS_ORIGIN=http://localhost:5173

# Docker Compose — production (docker-compose.prod.yml / docker compose up):
#   FRONTEND_PORT=8080  → UI http://localhost:8080, CORS_ORIGIN=http://localhost:8080
# Docker Compose — development (docker-compose.dev.yml):
#   FRONTEND_PORT=5173  → Vite UI at http://localhost:5173; API at http://localhost:8080
#   VITE_API_PROXY_TARGET is set only in docker-compose.dev.yml (http://backend:8080 inside the network).
#   Do not add VITE_API_PROXY_TARGET to this file for docker dev — the frontend service does not use env_file here.
# FRONTEND_PORT=8080

# Default admin — sign in at /login with this email + password.
# User is created on first backend start if no account with this email exists yet.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme
ADMIN_NAME=Admin

# Frontend (optional; Vite reads env from frontend/ — see vite.config.ts proxy)
# VITE_API_BASE=/api
#
# VITE_API_PROXY_TARGET — where the Vite dev server proxies /api (Node on your machine).
# Omit it or use localhost when backend runs on the host (default in vite.config.ts: http://localhost:8080).
# Do NOT set http://backend:8080 in frontend/.env or shell when running npm run dev on the host:
# the hostname "backend" only resolves inside Docker Compose (ENOTFOUND otherwise).
# For docker-compose.dev.yml, the frontend container gets VITE_API_PROXY_TARGET from compose, not from this file.
# VITE_API_PROXY_TARGET=http://localhost:8080
